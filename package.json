{
  "name": "@utopia-ai/cli",
  "version": "0.1.3",
  "description": "Production-aware probes that give AI coding agents real-time context about how code runs in production",
  "type": "module",
  "bin": {
    "utopia": "bin/utopia.js"
  },
  "files": [
    "bin/",
    "src/",
    "python/utopia_runtime/",
    "python/instrumenter/",
    "python/pyproject.toml",
    "python/README.md",
    "scripts/"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli/index.ts",
    "start:server": "tsx src/server/index.ts",
    "start:mcp": "tsx src/mcp/index.ts"
  },
  "keywords": [
    "cli",
    "probes",
    "observability",
    "ai",
    "claude",
    "codex",
    "production-context"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@babel/core": "^7.26.0",
    "@babel/generator": "^7.26.0",
    "@babel/parser": "^7.26.0",
    "@babel/traverse": "^7.26.0",
    "@babel/types": "^7.26.0",
    "@modelcontextprotocol/sdk": "^1.7.0",
    "better-sqlite3": "^11.7.0",
    "chalk": "^5.4.0",
    "commander": "^13.0.0",
    "express": "^4.21.0",
    "inquirer": "^12.3.0",
    "uuid": "^11.0.0",
    "tsx": "^4.19.0"
  },
  "devDependencies": {
    "@types/babel__core": "^7.20.5",
    "@types/babel__generator": "^7.6.8",
    "@types/babel__traverse": "^7.20.6",
    "@types/better-sqlite3": "^7.6.12",
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
